diff --git a/build/config/c++/BUILD.gn b/build/config/c++/BUILD.gn
index 013d2e5e1bc1..c864ea145f3a 100644
--- a/build/config/c++/BUILD.gn
+++ b/build/config/c++/BUILD.gn
@@ -29,6 +29,19 @@ config("runtime_library") {
     if (!export_libcxxabi_from_executables && !is_win) {
       defines += [ "_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS" ]
     }
+
+    # libc++ 21 uses _LIBCPP_OVERRIDABLE_FUNC_VIS for verbose_abort in
+    # addition to allocator entry points. The static libc++ target keeps that
+    # macro default-visible so Chromium's allocator can override new/delete,
+    # which otherwise leaks verbose_abort from every shared library that pulls
+    # it from the archive. Keep archive-provided runtime symbols local while
+    # leaving Chromium-provided allocator symbols unaffected.
+    if (is_tizen && !is_win) {
+      ldflags += [
+        "-Wl,--exclude-libs=libc++.a",
+        "-Wl,--exclude-libs=libc++abi.a",
+      ]
+    }
   }
 
