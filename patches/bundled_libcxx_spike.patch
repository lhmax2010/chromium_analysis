diff --git a/wrt/cxx_wrapper/build.sh b/wrt/cxx_wrapper/build.sh
new file mode 100755
index 000000000000..1bbd4831391d
--- /dev/null
+++ b/wrt/cxx_wrapper/build.sh
@@ -0,0 +1,42 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+profile=${1:-}
+output_dir=${2:?output directory is required}
+version_major=${3:?Tizen major version is required}
+version_minor=${4:?Tizen minor version is required}
+version_patch=${5:?Tizen patch version is required}
+source_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
+
+mkdir -p "$output_dir"
+
+packages=(wgt-manifest-handlers)
+sources=("$source_dir/wgt_manifest_handlers.cc")
+tv_define=
+
+if [[ "$profile" == "tv" ]]; then
+  packages+=(dlog settings-api)
+  sources+=("$source_dir/tv/settings_api.cc")
+  tv_define=-DOS_TIZEN_TV_PRODUCT
+fi
+
+read -r -a package_cflags <<< "$(pkg-config --cflags "${packages[@]}")"
+read -r -a package_libs <<< "$(pkg-config --libs "${packages[@]}")"
+
+gcc \
+  -shared \
+  -std=c++17 \
+  -O2 \
+  -fPIC \
+  -Wl,--no-undefined \
+  -Wl,-soname,libwrt-c++wrapper.so \
+  -Wl,--version-script,"$source_dir/wrt-c++wrapper.map" \
+  -DTIZEN_VERSION_MAJOR="$version_major" \
+  -DTIZEN_VERSION_MINOR="$version_minor" \
+  -DTIZEN_VERSION_PATCH="$version_patch" \
+  ${tv_define:+$tv_define} \
+  "${package_cflags[@]}" \
+  "${sources[@]}" \
+  "${package_libs[@]}" \
+  -lstdc++ \
+  -o "$output_dir/libwrt-c++wrapper.so"
